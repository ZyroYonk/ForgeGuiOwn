    -- STRIKEX-STYLE TOGGLE BUTTON (bigger, 110x110, never disappears, always draggable, red gradient stroke)
    function Window:AddToggleButton()
        if Library.ToggleButton then return end
        
        if not Library.ToggleButtonGui then
            Library.ToggleButtonGui = Instances:Create("ScreenGui", {
                Parent = gethui(),
                Name = "StrikeXMenuGUI",
                ZIndexBehavior = Enum.ZIndexBehavior.Global,
                DisplayOrder = 999,
                ResetOnSpawn = false
            })
        end
        
        local Button = Instances:Create("ImageButton", {
            Parent = Library.ToggleButtonGui.Instance,
            Name = "StrikeXToggle",
            Image = "rbxassetid://77596720579122",
            BackgroundColor3 = FromRGB(30, 30, 30),
            Size = UDim2New(0, 110, 0, 110),  -- BIGGER (was 80)
            Position = UDim2New(0, 70, 0, 70),
            AutoButtonColor = true,
            BorderSizePixel = 0,
            ZIndex = 10,
            Visible = true
        })
        
        Instances:Create("UICorner", {
            Parent = Button.Instance,
            CornerRadius = UDimNew(0, 20) -- adjusted for larger size
        })
        
        local Stroke = Instances:Create("UIStroke", {
            Parent = Button.Instance,
            Thickness = 3,
            Color = FromRGB(255, 0, 0),
            ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        })
        
        local Gradient = Instances:Create("UIGradient", {
            Parent = Stroke.Instance,
            Rotation = 45,
            Color = RGBSequence{
                RGBSequenceKeypoint(0, FromRGB(255, 100, 100)),
                RGBSequenceKeypoint(1, FromRGB(150, 0, 0))
            }
        })
        
        local dragging = false
        local dragStart = nil
        local startPos = nil
        local screenSize = Library.ToggleButtonGui.Instance.AbsoluteSize
        
        task.spawn(function()
            while Library.ToggleButtonGui and Button do
                screenSize = Library.ToggleButtonGui.Instance.AbsoluteSize
                task.wait(0.5)
            end
        end)
        
        local function onInputBegan(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStart = input.Position
                startPos = Button.Instance.Position
            end
        end
        
        local function onInputChanged(input)
            if not dragging then return end
            if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
            
            local delta = input.Position - dragStart
            local newX = startPos.X.Offset + delta.X
            local newY = startPos.Y.Offset + delta.Y
            
            -- Dynamically clamp using button's actual size
            local btnSize = Button.Instance.AbsoluteSize
            newX = math.clamp(newX, 0, screenSize.X - btnSize.X)
            newY = math.clamp(newY, 0, screenSize.Y - btnSize.Y)
            
            Button.Instance.Position = UDim2New(0, newX, 0, newY)
        end
        
        local function onInputEnded(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = false
                dragStart = nil
                startPos = nil
            end
        end
        
        Button:Connect("InputBegan", onInputBegan)
        Button:Connect("InputEnded", onInputEnded)
        Library:Connect(UserInputService.InputChanged, onInputChanged)
        
        local tapTime = nil
        Button:Connect("InputBegan", function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                tapTime = tick()
            end
        end)
        Button:Connect("InputEnded", function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                if tapTime and (tick() - tapTime) < 0.3 and not dragging then
                    Window:SetOpen(not Window.IsOpen)
                end
                tapTime = nil
            end
        end)
        
        Library.ToggleButton = Button
        return Button
    end

    Library:Connect(UserInputService.InputBegan, function(Input)
        if tostring(Input.KeyCode) == Library.MenuKeybind or tostring(Input.UserInputType) == Library.MenuKeybind then
            Window:SetOpen(not Window.IsOpen)
        end
    end)

    Window:SetCenter()
    task.wait()
    Window:SetOpen(true)
    return setmetatable(Window, Library)
end

