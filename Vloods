        for Index, Value in self.Connections do 
            Value.Connection:Disconnect()
        end

        for Index, Value in self.Threads do 
            coroutine.close(Value)
        end

        if self.Holder then 
            self.Holder:Clean()
        end
        if self.ToggleButtonGui then
            self.ToggleButtonGui:Clean()
        end

        Library = nil 
        getgenv().Library = nil
    end

