        -- NEW: Discord Webhook Section (Textbox for URL + Send button + optional keybind)
        Library.Sections.Webhook = function(self, Data)
            Data = Data or {}
            local Section = self
            
            local WebhookObj = {
                Url = "",
                SendCallback = Data.Callback or function() end,
                Keybind = nil,
                SendButton = nil,
                UrlTextbox = nil,
            }
            
            -- Textbox for URL
            WebhookObj.UrlTextbox = Section:Textbox({
                Name = Data.Name or "Webhook URL",
                Placeholder = "https://discord.com/api/webhooks/...",
                Flag = Data.Flag or Library:NextFlag(),
                Callback = function(url)
                    WebhookObj.Url = url
                end
            })
            
            -- Send Button
            WebhookObj.SendButton = Section:Button({
                Name = "Send Test Message",
                Callback = function()
                    if WebhookObj.Url == "" then return end
                    local data = {
                        content = Data.Message or "Hello from GUI!",
                        embeds = Data.Embeds or {},
                        username = Data.Username or "Webhook",
                    }
                    local success, err = pcall(function()
                        local response = HttpService:PostAsync(WebhookObj.Url, HttpService:JSONEncode(data), Enum.HttpContentType.ApplicationJson)
                    end)
                    if success then
                        Library:Notification("Webhook sent successfully!", 3)
                        if WebhookObj.SendCallback then
                            Library:SafeCall(WebhookObj.SendCallback, WebhookObj.Url)
                        end
                    else
                        Library:Notification("Failed to send webhook: " .. tostring(err), 4)
                    end
                end
            })
            
            -- Optional Keybind to trigger send
            if Data.Keybind then
                WebhookObj.Keybind = Section:Keybind({
                    Title = "Send Webhook Keybind",
                    Value = Data.Keybind.Default or "G",
                    Callback = function(toggled)
                        if toggled then
                            WebhookObj.SendButton:Press()
                        end
                    end
                })
            end
            
            return WebhookObj
        end
    end

